{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "screenshots": "node scripts/screenshots.mjs",
    "lint": "oxlint -c .oxlintrc.json --disable-nested-config src/",
    "fmt": "oxfmt -c .oxfmtrc.json --write src/",
    "fmt:check": "oxfmt -c .oxfmtrc.json --check src/"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "22.16.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@shikijs/rehype": "^4.2.0",
    "github-markdown-css": "^5.8.1",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "plantuml-encoder": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "rehype-github-alerts": "^4.2.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "playwright": "^1.61.0",
    "rollup-plugin-license": "^3.7.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
